# Cloudflare Pages response headers for the standalone teleop playground.
# Docs: https://developers.cloudflare.com/pages/configuration/headers/
#
# Vite copies playground/public/* into dist/, so this policy ships with the build.
# Same profile as the site: content-hashed WASM/JS cached forever, WASM MIME forced.
# Decision: infra/decisions/017-hosting-and-deploy.md.

# Content-hashed Vite build assets (name changes when bytes change → cache forever).
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Force the WASM media type for streaming compile (mujoco-wasm + onnxruntime-web).
/assets/*.wasm
  Content-Type: application/wasm

# Toy/preloaded .onnx policies (git-ignored, generated by scripts/make_toy_onnx.py).
# Stable filenames → revalidate rather than pin.
/models/*
  Cache-Control: public, max-age=3600, must-revalidate
