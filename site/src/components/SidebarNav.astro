---
// SidebarNav — the chapter index grouped by phase (Phase 0 / Phase 1 → chapters
// by number + title). Fully static; the current chapter is marked
// aria-current="page". Reading-progress JS (in ChapterLayout) decorates visited
// links with a data-read attribute at runtime, but the nav is complete without JS.
import { chaptersByPhase, discoverFurther, type ChapterInfo } from "../lib/curriculum.ts";
import ThemeToggle from "./ThemeToggle.tsx";

interface Props {
  chapters: ChapterInfo[];
  currentSlug?: string;
}
const { chapters, currentSlug } = Astro.props;
const groups = chaptersByPhase(chapters);

// Phase-5 prose appendices (reading track + graduation bridge). Not chapters, so
// they never appear in `chapters` — group them by track so the nav lists them
// after the phases, each linking a real /further/ page.
const further = discoverFurther();
const furtherGroups = [...new Map(further.map((m) => [m.track, m.trackLabel])).entries()].map(
  ([track, label]) => ({ track, label, modules: further.filter((m) => m.track === track) }),
);
const currentPath = Astro.url.pathname;

// Label shown on the mobile "Chapters" disclosure summary so a reader knows where
// they are without expanding the full index. Chapter pages only; other pages fall
// back to the bare "Chapters" label.
const currentChapter = currentSlug ? chapters.find((c) => c.slug === currentSlug) : undefined;
const currentLabel = currentChapter ? `${currentChapter.number} · ${currentChapter.title}` : undefined;
---

<nav class="sidebar" aria-label="Chapters">
  <div class="sidebar__top">
    <a class="sidebar__brand" href="/">zero2robot</a>
    <ThemeToggle client:only="preact" />
  </div>

  {/* Search + help are JS-only (the overlay islands need JS); the "/" · ⌘K · ?
      keybinds also open them. Hidden without JS; reading is unaffected. */}
  <div class="sidebar__util">
    <button class="sidebar__search" type="button" data-search-open hidden>
      <span>Search</span><kbd>/</kbd>
    </button>
    <button class="sidebar__search" type="button" data-help-open hidden>
      <span>Help</span><kbd>?</kbd>
    </button>
  </div>

  <ul class="sidebar__quicklinks">
    <li><a href="/about/" aria-current={currentSlug === undefined && Astro.url.pathname.startsWith("/about") ? "page" : undefined}>About</a></li>
    <li><a href="/map/" aria-current={currentSlug === undefined && Astro.url.pathname.startsWith("/map") ? "page" : undefined}>Learning map</a></li>
  </ul>

  {/* The full 43-chapter index. Native <details> so it collapses on phones
      (see the styles.css ≤62rem rules + the sync script below) with zero JS and
      full keyboard support. It ships `open` so desktop and JS-off both render the
      whole index; the summary is hidden above the breakpoint and only becomes a
      tappable "Chapters" bar on narrow screens. */}
  <details class="sidebar__disclosure" open>
    <summary class="sidebar__disclosure-summary">
      <span class="sidebar__disclosure-label">Chapters</span>
      {currentLabel && <span class="sidebar__disclosure-current">{currentLabel}</span>}
    </summary>
    <div class="sidebar__groups">
  {
    groups.map((g) => (
      <div class="sidebar__phase">
        {/* nav group LABEL, not a document heading — keeps the page heading
            outline (h1 → h2 …) intact rather than injecting sidebar h2s first. */}
        <p class="sidebar__phase-label" id={`ph-${g.phaseKey}`}>{g.phaseLabel}</p>
        <ul class="sidebar__list" aria-labelledby={`ph-${g.phaseKey}`}>
          {g.chapters.map((ch) => (
            <li class="sidebar__item">
              <a
                class="sidebar__link"
                href={`/${ch.slug}/`}
                data-chapter={ch.slug}
                aria-current={ch.slug === currentSlug ? "page" : undefined}
              >
                <span class="sidebar__num">{ch.number}</span>
                <span class="sidebar__title">{ch.title}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    ))
  }

  {
    furtherGroups.map((fg) => (
      <div class="sidebar__phase">
        <p class="sidebar__phase-label" id={`fx-${fg.track}`}>{fg.label}</p>
        <ul class="sidebar__list" aria-labelledby={`fx-${fg.track}`}>
          {fg.modules.map((m) => {
            const href = `/further/${m.track}/${m.slug}/`;
            return (
              <li class="sidebar__item">
                <a
                  class="sidebar__link"
                  href={href}
                  aria-current={currentPath === href ? "page" : undefined}
                >
                  <span class="sidebar__num">{m.badge}</span>
                  <span class="sidebar__title">{m.title}</span>
                </a>
              </li>
            );
          })}
        </ul>
      </div>
    ))
  }
    </div>
  </details>
</nav>

<script>
  // Reveal + wire the search affordance once JS is available; dispatch the event
  // the SearchOverlay island listens for (works regardless of hydration order).
  for (const b of document.querySelectorAll<HTMLElement>("[data-search-open]")) {
    b.hidden = false;
    b.addEventListener("click", () => window.dispatchEvent(new Event("z2r:search-open")));
  }
  for (const b of document.querySelectorAll<HTMLElement>("[data-help-open]")) {
    b.hidden = false;
    b.addEventListener("click", () => window.dispatchEvent(new Event("z2r:help-open")));
  }

  // Responsive disclosure: collapse the chapter index on phones, expand it on
  // wider screens. The markup ships `open` so JS-off desktop keeps the full
  // index; this only *closes* it under the ≤62rem breakpoint (where the summary
  // becomes a tappable "Chapters" bar) and re-opens it above. Fires on load and
  // only when the breakpoint is crossed — a reader's own toggle in between is
  // left alone. Native <details> means keyboard + a11y are free; no focus trap.
  const disclosure = document.querySelector<HTMLDetailsElement>(".sidebar__disclosure");
  if (disclosure) {
    const mq = window.matchMedia("(max-width: 62rem)");
    const sync = () => {
      disclosure.open = !mq.matches;
    };
    sync();
    mq.addEventListener("change", sync);
  }
</script>
