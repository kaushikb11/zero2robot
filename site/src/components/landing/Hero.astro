---
// Hero.astro — the top of the landing FRAME (feature F3).
//
// The product promise + the flagship covariate-shift toy as the "wow", plus a
// primary CTA and a SLOT for F2's progress-aware "continue" widget.
//
// COPY: the landing copy here is FINAL (author-owned prose, voice-checked
// against the ch1.1/ch1.6 exemplars). The hero's centerpiece (HeroDemo → the
// real bc_policy.onnx + MuJoCo-WASM toy) is NOT copy; it is the real thing,
// reused verbatim, and it degrades to its SSR poster with JS off.
//
// SSR / JS-OFF: this component is fully server-rendered. The headline, CTAs and
// the toy's poster + caption survive a <script> strip. Only the live sim (inside
// HeroDemo/PlateIsland) needs JS, and it is hydration-gated + lazy by contract.
import HeroDemo from "../HeroDemo.astro";
import { discoverChapters } from "../../lib/curriculum.ts";
import "./landing.css";

// Links are DERIVED from the real curriculum, never hand-typed — so they can
// never point at a chapter that doesn't exist.
const chapters = discoverChapters();
const first = chapters[0] ?? null;
const flagship = chapters.find((c) => c.demo === "pusht_bc_recovery") ?? null;

const startHref = first ? `/${first.slug}/` : "#curriculum";

// The toy's "See it work" caption. On the landing this is ONE sentence — the
// first impression is the toy itself, not the copy — with a link into ch1.1 for
// the "why". Instructional + factual, in the house voice; no marketing.
const heroLedeHtml = `
  <p>Drag the block out of the region the demos covered, and watch a confident
  policy fail. <a href="/ch1.1-bc/">Why it fails &rarr;</a></p>
`;

---

<section class="ln-hero" aria-labelledby="ln-hero-title">
  <div class="ln-hero__grid">
    <div class="ln-hero__lead">
      <p class="ln-kicker">Interactive textbook · embodied AI, from scratch</p>

      <h1 class="ln-title" id="ln-hero-title">
        Build a robot brain.
        <span class="ln-title__accent">No robot required.</span>
      </h1>

      <p class="ln-subhead">
        Embodied AI from scratch, one runnable file per chapter, from a bare
        simulation loop to a policy you train, export, and drive in your browser.
        No framework to excavate, no black boxes. Free on a Colab T4 or your laptop.
      </p>

      <!-- ONE primary action. The landing used to offer three competing entry
           points (two hero buttons, a progress "start", a sidebar "start here");
           the whole point of the declutter is a single obvious thing to do. -->
      <div class="ln-cta">
        <a class="ln-btn ln-btn--primary" href={startHref}>
          Start from the first page
          {first && <span class="ln-btn__sub">{first.number} · {first.artifactBasename}</span>}
        </a>
      </div>

      <p class="ln-hero__reassure">
        No account, no setup, and your place is remembered locally in your browser.
      </p>
    </div>

    <div class="ln-hero__demo">
      <HeroDemo demo="pusht_bc_recovery" task="pusht" variant="hero" ledeHtml={heroLedeHtml} />
    </div>
  </div>
</section>
