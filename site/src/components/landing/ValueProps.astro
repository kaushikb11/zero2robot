---
// ValueProps.astro — a "what makes this different" strip between the hero and
// the curriculum arc. Three claims that match the project's actual invariants
// (free-tier floor, real code, honest provenance).
//
// COPY: final author-owned prose, voice-checked. The invariants underneath are
// real (root CLAUDE.md); the wording is finished. Fully server-rendered; no JS.
import "./landing.css";

const PROPS: { eyebrow: string; title: string; body: string }[] = [
  {
    eyebrow: "the code is the product",
    title: "One file you can read top to bottom",
    body:
      "Every chapter builds a single runnable script — a few hundred lines, no framework to excavate. You read it like a textbook, and every line you read is a line that runs.",
  },
  {
    eyebrow: "runs on the free tier",
    title: "A laptop or a free Colab T4 is enough",
    body:
      "Every learner-facing path completes on CPU or a free T4. The wall-clock times on each page are measured on real hardware, never estimated; where a tier hasn't been measured yet, the page says so.",
  },
  {
    eyebrow: "honest by construction",
    title: "Real sims, real policies, real numbers",
    body:
      "The browser demos run the same code you train locally. Seeds are mandatory, results reproduce within a recorded band, and every number you read traces back to a run — including the ones that show a method failing.",
  },
];
---

<section class="ln-props" aria-labelledby="ln-props-title">
  <div class="ln-props__head">
    <h2 class="ln-kicker" id="ln-props-title">Why this course is built the way it is</h2>
  </div>

  <ul class="ln-props__grid">
    {
      PROPS.map((p) => (
        <li class="ln-prop">
          <p class="ln-prop__eyebrow">{p.eyebrow}</p>
          <h3 class="ln-prop__title">{p.title}</h3>
          <p class="ln-prop__body">{p.body}</p>
        </li>
      ))
    }
  </ul>
</section>
