---
// Further-reading module route — one page per Phase-5 prose appendix: the
// practitioner reading track (/further/reading/…) and the graduation "go build"
// bridge (/further/graduation/…). These are prose-only curriculum modules (no
// meta.yaml, so discoverChapters skips them); we surface them here so they are
// reachable, not orphaned.
//
// Like the chapter pages, everything reads from curriculum/ via the bridge
// (readProse) and renders server-side, so the module reads with JavaScript off.
// The prose is rendered by lib/prose.ts (renderModuleProse) — the same marked +
// heading-id pipeline the chapter pages use, minus the code-panel machinery.
import ChapterLayout from "../../../layouts/ChapterLayout.astro";
import PrevNext from "../../../components/PrevNext.astro";
import {
  discoverChapters,
  discoverFurther,
  readProse,
  type ChapterInfo,
  type FurtherModule,
} from "../../../lib/curriculum.ts";
import { renderModuleProse } from "../../../lib/prose.ts";

// The further modules continue the one journey, so each carries prev/next like a
// chapter: p1's "Previous" reaches back to the last chapter (5.8), the modules
// chain p1→p2→p3→g1→g2→g3, and G3 — the finale — ends with a "go build" send-off
// (finish) instead of a bare dead-end. Links are generic {href,label,kicker}.
interface NavLink {
  href: string;
  label: string;
  kicker?: string;
}

export function getStaticPaths() {
  // Helpers live INSIDE getStaticPaths (Astro hoists it above the frontmatter
  // consts, so module-scope consts would be in their temporal dead zone here).
  const chapterLink = (c: ChapterInfo): NavLink => ({
    href: `/${c.slug}/`,
    label: `${c.number} · ${c.title}`,
    kicker: c.phaseLabel,
  });
  const moduleLink = (m: FurtherModule): NavLink => ({
    href: `/further/${m.track}/${m.slug}/`,
    label: m.badge ? `${m.badge} · ${m.title}` : m.title,
    kicker: m.trackLabel,
  });

  const chapters = discoverChapters();
  const further = discoverFurther(); // [p1,p2,p3,g1,g2,g3]
  return further.map((m, i) => {
    const prev: NavLink | null =
      i > 0
        ? moduleLink(further[i - 1])
        : chapters.length > 0
          ? chapterLink(chapters[chapters.length - 1]) // p1 → back to the last chapter (5.8)
          : null;
    const next: NavLink | null =
      i < further.length - 1 ? moduleLink(further[i + 1]) : null;
    return {
      params: { track: m.track, module: m.slug },
      props: { module: m, prev, next, finish: i === further.length - 1 },
    };
  });
}

interface Props {
  module: FurtherModule;
  prev: NavLink | null;
  next: NavLink | null;
  finish: boolean;
}
const { module, prev, next, finish } = Astro.props;
const bodyHtml = renderModuleProse(readProse(module.proseRel));
---

<ChapterLayout title={`${module.title} — zero2robot`}>
  <div class="bk-titleblock">
    <p class="bk-kicker">{module.trackLabel}</p>
    <h1 class="bk-title">
      {module.badge && <span class="bk-title-sub">{module.badge}</span>}
      {module.title}
    </h1>
  </div>

  <article class="bk-prose" set:html={bodyHtml} />

  <PrevNext slot="prevnext" prev={prev} next={next} finish={finish} />
</ChapterLayout>
